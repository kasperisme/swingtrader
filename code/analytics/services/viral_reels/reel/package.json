{
  "name": "viral-reels-renderer",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion renderer for News Impact Screener data reels (bar chart race).",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts BarChartRace out/reel.mp4",
    "render:sample": "remotion render src/index.ts BarChartRace out/reel.mp4",
    "still": "remotion still src/index.ts BarChartRace out/frame.png --frame=180",
    "upgrade": "remotion upgrade",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.4.0"
  }
}
