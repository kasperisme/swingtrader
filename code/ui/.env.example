X_CLIENT_ID=your-x-oauth-client-id
X_CLIENT_SECRET=your-x-oauth-client-secret-optional
X_REDIRECT_URI=http://localhost:3000/auth/x/callback
X_OAUTH_SCOPE=tweet.read users.read offline.access

