# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
FMP_API_KEY=your-fmp-api-key
X_CLIENT_ID=your-x-oauth-client-id
X_CLIENT_SECRET=your-x-oauth-client-secret-optional
X_REDIRECT_URI=http://localhost:3000/auth/x/callback
X_OAUTH_SCOPE=tweet.read users.read offline.access

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_INVESTOR_MONTHLY_PRICE_ID=price_...
STRIPE_INVESTOR_ANNUAL_PRICE_ID=price_...
STRIPE_TRADER_MONTHLY_PRICE_ID=price_...
STRIPE_TRADER_ANNUAL_PRICE_ID=price_...

# HuggingFace
HF_TOKEN=your-huggingface-api-token

# Resend (transactional email + audiences)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=News Impact Screener <noreply@newsimpactscreener.com>
RESEND_REPLY_TO=
# Optional: Resend Segment ID for waitlist contacts. Leave blank to skip segment sync.
# (Resend replaced Audiences with Segments in late 2025.)
RESEND_WAITLIST_SEGMENT_ID=
# Resend stored-template ID (UUID) or alias for the waitlist welcome email.
# Variables available: email, appUrl. (Waitlist signups only collect email.)
RESEND_WAITLIST_WELCOME_TEMPLATE_ID=
# Resend stored-template ID (UUID) or alias for the post-signup welcome email.
# Variables available: firstName, email, appUrl.
RESEND_WELCOME_TEMPLATE_ID=

# Onboarding tutorial. NEXT_PUBLIC_TUTORIAL_VIDEO_URL is an embeddable URL
# (e.g. https://www.youtube.com/embed/VIDEO_ID). When unset, the welcome dialog
# opens NEXT_PUBLIC_TUTORIAL_PLAYLIST_URL in a new tab instead.
NEXT_PUBLIC_TUTORIAL_VIDEO_URL=
NEXT_PUBLIC_TUTORIAL_PLAYLIST_URL=https://www.youtube.com/@newsimpactscreener

# Instagram latest-posts feed on the landing page, via Behold (https://behold.so).
# Create a feed at behold.so, then set this to the feed id — the trailing segment
# of the feed URL https://feeds.behold.so/<id>. Leave blank to show only a
# "Follow on Instagram" CTA (no live posts).
BEHOLD_FEED_ID=

# Public app URL used inside email templates
NEXT_PUBLIC_APP_URL=https://newsimpactscreener.com

# PostHog product analytics. Get the project key from PostHog → Project Settings.
# Host defaults to "/ingest" (proxied via next.config.ts rewrites to bypass ad blockers).
# Override only if self-hosting or using the EU region.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest
# Server-side PostHog host (used by posthog-node in API routes). Defaults to EU region.
POSTHOG_HOST=https://eu.i.posthog.com

# Email subscription flow (lightweight, no-account screening delivery)
# HMAC secret for signing one-click unsubscribe links (/api/unsubscribe).
UNSUBSCRIBE_SECRET=
# Public Telegram join URL for the article screener-bridge CTA. If unset, the
# app derives https://t.me/<TELEGRAM_BOT_USERNAME>; if neither is set the
# "Join Telegram" button is omitted.
NEXT_PUBLIC_TELEGRAM_JOIN_URL=
# Slug of the screening the article→screener bridge CTA points at.
NEXT_PUBLIC_BRIDGE_SCREENING_SLUG=nis-momentum
